{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": ["pip"],
      "enabled": true,
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchManagers": ["dockerfile"],
      "enabled": true,
      "automerge": true
    }
  ]
}
